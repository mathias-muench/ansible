[alias]
	st = status -sb
	cl = clean -f -d
	ad = add -uv
	ci = commit
	rb = rebase -i
	fe = fetch --prune --all
	mg = merge --ff-only
	df = diff --relative
	lg = log --oneline
	ln = log --oneline --name-only
	dn = diff --name-only
	aa = add -Av
	pf = push --force-with-lease
	ls = ls-files
[includeIf "urlmatch:https://github.com/**"]
    [user]
        name = Mathias Muench
        email = mathias-muench@users.noreply.github.com
    [credential "https://github.com"]
        helper = !gh auth git-credential
